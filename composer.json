{
    "name": "noo/craft-twig-helpers",
    "description": "Shared Twig helpers for Craft CMS with config-based extensibility.",
    "type": "craft-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Joris Noordermeer",
            "email": "contact@noordermeer.ch"
        }
    ],
    "autoload": {
        "psr-4": {
            "Noo\\CraftTwigHelpers\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^4.0.0 || ^5.0.0"
    },
    "require-dev": {
        "laravel/pint": ">=1.18.1"
    },
    "scripts": {
        "lint": "pint"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
